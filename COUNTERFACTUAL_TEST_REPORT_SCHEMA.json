{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenarios_tested",
    "expected_failures",
    "observed_failures",
    "escaped_failures",
    "distinguishing_signals",
    "result"
  ],
  "properties": {
    "scenarios_tested": {"type": "array", "items": {"type": "string"}},
    "expected_failures": {"type": "array", "items": {"type": "string"}},
    "observed_failures": {"type": "array", "items": {"type": "string"}},
    "escaped_failures": {"type": "array", "items": {"type": "string"}},
    "distinguishing_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["signal_type", "pre_hash", "post_hash"],
        "properties": {
          "signal_type": {"type": "string"},
          "pre_hash": {"type": "string"},
          "post_hash": {"type": "string"}
        }
      }
    },
    "result": {"type": "string", "enum": ["PASS", "FAIL"]}
  }
}
